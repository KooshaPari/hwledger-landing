---
import "../styles/globals.css";
import readmeSnapshot from "../data/readme.html?raw";
import { sitePath } from "../lib/site";

// Fetch repo metadata + README at build time. Strategy: try live GitHub API
// (uses GITHUB_TOKEN if set in Vercel env to avoid 60/hr unauthenticated rate
// limit), but ALWAYS fall back to a committed snapshot so the page never
// ships with "README unavailable". Refresh snapshots locally with
// `bun run data:refresh`.
const REPO = "KooshaPari/hwLedger";
const SITE_URL = "https://hwledger.kooshapari.com";
const PAGE_TITLE = "hwLedger - LLM fleet capacity planner";
const FALLBACK_DESCRIPTION =
  "hwLedger plans VRAM, reconciles inference telemetry, and ledgers local and cloud accelerator fleets for agent-native LLM operations.";
const GITHUB_TOKEN = process.env.GITHUB_TOKEN;

async function gh<T = unknown>(
  path: string,
  accept = "application/vnd.github+json",
): Promise<T | null> {
  try {
    const res = await fetch(`https://api.github.com/${path}`, {
      headers: {
        Accept: accept,
        "User-Agent": "hwledger-landing-build",
        ...(GITHUB_TOKEN
          ? { Authorization: `Bearer ${GITHUB_TOKEN}` }
          : {}),
      },
    });
    if (!res.ok) {
      console.warn(`[index] GitHub ${path} -> ${res.status}; falling back to snapshot`);
      return null;
    }
    return (accept.includes("html") ? await res.text() : await res.json()) as T;
  } catch (err) {
    console.warn(`[index] GitHub ${path} fetch failed: ${(err as Error).message}; falling back to snapshot`);
    return null;
  }
}

const meta: any = (await gh(`repos/${REPO}`)) ?? {
  description: "",
  stargazers_count: 0,
  pushed_at: new Date().toISOString(),
  language: "Rust",
  homepage: "",
};
const PAGE_DESCRIPTION = meta.description || FALLBACK_DESCRIPTION;
const DEMO_STEPS = [
  { label: "Inventory", value: "GPU / VRAM / runtime" },
  { label: "Fit", value: "model + KV cache budget" },
  { label: "Ship", value: "capacity plan + runbook" },
];

const liveReadme = await gh<string>(
  `repos/${REPO}/readme`,
  "application/vnd.github.html+json",
);
const readmeHtml: string = liveReadme ?? readmeSnapshot;

const releases: any[] = (await gh<any[]>(`repos/${REPO}/releases?per_page=5`)) ?? [];
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{PAGE_TITLE}</title>
    <meta name="description" content={PAGE_DESCRIPTION} />
    <link rel="canonical" href={SITE_URL} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="hwLedger" />
    <meta property="og:title" content={PAGE_TITLE} />
    <meta property="og:description" content={PAGE_DESCRIPTION} />
    <meta property="og:url" content={SITE_URL} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={PAGE_TITLE} />
    <meta name="twitter:description" content={PAGE_DESCRIPTION} />
    <meta name="theme-color" content="#7ebab5" />
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2284%22>H</text></svg>" />
  </head>
  <body class="min-h-screen">
    <main class="max-w-4xl mx-auto px-6 py-12">
      <header class="hero-shell mb-12">
        <div>
          <div class="mono text-xs text-[var(--muted)] mb-2">
            <a href="https://projects.kooshapari.com" class="hover:text-[var(--accent)]">phenotype</a>
            <span class="mx-1">/</span>
            <span>hwledger</span>
          </div>
          <h1 class="text-5xl md:text-6xl font-bold tracking-tight mb-3">hwLedger</h1>
          <p class="text-lg text-[var(--muted)] max-w-2xl">{PAGE_DESCRIPTION}</p>

          <div class="mt-6 flex flex-wrap gap-3 mono text-sm">
            <a href={`https://github.com/${REPO}`} target="_blank" rel="noopener"
               class="px-4 py-2 rounded-lg border bg-[var(--card)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition"
               style="border-color: var(--border);">
              github →
            </a>
            <a href={sitePath("/docs")}
               class="px-4 py-2 rounded-lg border bg-[var(--card)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition"
               style="border-color: var(--border);">
              docs →
            </a>
            <a href={sitePath("/qa")}
               class="px-4 py-2 rounded-lg border bg-[var(--card)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition"
               style="border-color: var(--border);">
              qa →
            </a>
            <span class="px-4 py-2 rounded-lg mono text-xs text-[var(--muted)] flex items-center gap-2"
                  style="border: 1px solid var(--border);">
              ★ {meta.stargazers_count} · {meta.language ?? "Rust"}
            </span>
          </div>

          <ol class="demo-flow mt-8" aria-label="hwLedger demo flow">
            {DEMO_STEPS.map((step, index) => (
              <li>
                <span class="demo-index mono">{String(index + 1).padStart(2, "0")}</span>
                <strong>{step.label}</strong>
                <em>{step.value}</em>
              </li>
            ))}
          </ol>
        </div>

        <div class="capacity-panel" aria-label="hwLedger capacity planner snapshot">
          <div class="panel-head mono">
            <span>fleet ledger</span>
            <strong>macOS MVP</strong>
          </div>
          <div class="capacity-bars">
            <div><span style="--w: 78%"></span><em>VRAM fit</em></div>
            <div><span style="--w: 64%"></span><em>KV cache</em></div>
            <div><span style="--w: 52%"></span><em>tokens/sec</em></div>
          </div>
          <div class="proof-grid">
            <span>MLX</span>
            <span>GGUF</span>
            <span>Ollama</span>
            <span>mTLS</span>
          </div>
        </div>
      </header>

      {releases.length > 0 && (
        <section class="mb-10">
          <h2 class="mono text-sm uppercase tracking-wider text-[var(--muted)] mb-3">Latest releases</h2>
          <ul class="space-y-2">
            {releases.slice(0, 3).map((r: any) => (
              <li class="flex items-baseline gap-3 mono text-sm">
                <a href={r.html_url} target="_blank" rel="noopener" class="text-[var(--accent)] hover:underline">{r.tag_name}</a>
                <span class="text-[var(--muted)] truncate">{r.name ?? ""}</span>
                <span class="ml-auto text-xs text-[var(--muted)] shrink-0">{new Date(r.published_at).toLocaleDateString()}</span>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="readme-prose" set:html={readmeHtml}></section>

      <footer class="mt-16 pt-6 border-t text-xs text-[var(--muted)] mono" style="border-color: var(--border);">
        hwledger.kooshapari.com · auto-built from <a href={`https://github.com/${REPO}`} class="underline hover:text-[var(--accent)]">{REPO}</a> · part of <a href="https://projects.kooshapari.com" class="underline hover:text-[var(--accent)]">projects.kooshapari.com</a>
      </footer>
    </main>

    <style is:global>
      .hero-shell {
        display: grid;
        grid-template-columns: minmax(0, 1.15fr) minmax(18rem, 0.85fr);
        gap: 2rem;
        align-items: center;
      }
      .capacity-panel {
        border: 1px solid var(--border);
        border-radius: 0.75rem;
        background: var(--card);
        padding: 1.25rem;
        min-height: 18rem;
        display: grid;
        grid-template-rows: auto 1fr auto;
        gap: 1.25rem;
      }
      .panel-head {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        color: var(--muted);
        font-size: 0.78rem;
      }
      .panel-head strong {
        color: var(--accent);
      }
      .demo-flow {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.7rem;
        list-style: none;
        padding: 0;
      }
      .demo-flow li {
        border: 1px solid var(--border);
        border-radius: 0.55rem;
        background: color-mix(in oklab, var(--card) 86%, #d7f2ef 14%);
        padding: 0.8rem;
        min-width: 0;
      }
      .demo-index {
        display: block;
        color: var(--accent);
        font-size: 0.72rem;
        margin-bottom: 0.45rem;
      }
      .demo-flow strong,
      .demo-flow em {
        display: block;
      }
      .demo-flow strong {
        font-size: 0.95rem;
      }
      .demo-flow em {
        margin-top: 0.25rem;
        color: var(--muted);
        font-style: normal;
        font-size: 0.78rem;
        line-height: 1.35;
      }
      .capacity-bars {
        display: grid;
        gap: 0.8rem;
        align-content: center;
      }
      .capacity-bars div {
        display: grid;
        grid-template-columns: 1fr 5.5rem;
        gap: 0.8rem;
        align-items: center;
      }
      .capacity-bars span {
        display: block;
        height: 0.7rem;
        border: 1px solid var(--border);
        border-radius: 999px;
        overflow: hidden;
        background:
          linear-gradient(90deg, var(--accent) var(--w), var(--accent-wash) var(--w));
      }
      .capacity-bars em {
        color: var(--muted);
        font-style: normal;
        font-size: 0.78rem;
      }
      .proof-grid {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 0.55rem;
      }
      .proof-grid span {
        border: 1px solid var(--border);
        border-radius: 0.45rem;
        background: var(--accent-wash);
        padding: 0.6rem 0.4rem;
        color: var(--muted);
        text-align: center;
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        font-size: 0.75rem;
      }
      .readme-prose { line-height: 1.7; }
      .readme-prose h1, .readme-prose h2, .readme-prose h3 {
        font-weight: 700;
        margin-top: 2rem;
        margin-bottom: 0.75rem;
        line-height: 1.2;
      }
      .readme-prose h1 { font-size: 2rem; border-bottom: 1px solid var(--border); padding-bottom: 0.5rem; }
      .readme-prose h2 { font-size: 1.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.3rem; }
      .readme-prose h3 { font-size: 1.2rem; }
      .readme-prose p, .readme-prose ul, .readme-prose ol { margin-bottom: 1rem; }
      .readme-prose ul, .readme-prose ol { padding-left: 1.5rem; }
      .readme-prose li { margin-bottom: 0.25rem; }
      .readme-prose a { color: var(--accent); text-decoration: underline; }
      .readme-prose code {
        font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
        background: var(--card);
        padding: 0.1rem 0.4rem;
        border-radius: 0.25rem;
        font-size: 0.9em;
      }
      .readme-prose pre {
        background: var(--card);
        border: 1px solid var(--border);
        padding: 1rem;
        border-radius: 0.5rem;
        overflow-x: auto;
        margin-bottom: 1rem;
      }
      .readme-prose pre code { background: transparent; padding: 0; }
      .readme-prose blockquote {
        border-left: 3px solid var(--accent);
        padding-left: 1rem;
        color: var(--muted);
        margin: 1rem 0;
      }
      .readme-prose table { border-collapse: collapse; margin-bottom: 1rem; }
      .readme-prose th, .readme-prose td { border: 1px solid var(--border); padding: 0.5rem 0.75rem; }
      .readme-prose img { display: inline-block; }
      @media (max-width: 760px) {
        .hero-shell {
          grid-template-columns: 1fr;
        }
        .demo-flow {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </body>
</html>
